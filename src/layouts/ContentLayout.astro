---
import BaseLayout from './BaseLayout.astro';
import { getReadingTime } from '../lib/readingTime';
import Tag from '../components/Tag.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  connections?: string[];
  content: string;
  type: 'essay' | 'snippet' | 'idea';
}

const { title, description, date, updated, tags = [], connections = [], content, type } = Astro.props;
const readingTime = getReadingTime(content);
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const typeLabel = type.charAt(0).toUpperCase() + type.slice(1) + 's';
---

<BaseLayout title={title} description={description}>
  <div class="container">
    <header class="article-header">
      <a href={`/${type}s`} class="back-link">← Back to {typeLabel}</a>
      <h1>{title}</h1>
      <p class="description">{description}</p>
      <div class="metadata">
        <time>{formattedDate}</time>
        {readingTime && <span>· {readingTime} min read</span>}
      </div>
      {tags.length > 0 && (
        <div class="tags">
          {tags.map((tag) => (
            <Tag href={`/tags/${tag}`}>{tag}</Tag>
          ))}
        </div>
      )}
    </header>

    <hr />

    <article class="prose">
      <slot />
    </article>

    {connections && connections.length > 0 && (
      <>
        <hr />
        <section class="connections">
          <h2>Connections</h2>
          <ul>
            {connections.map((connection) => (
              <li>→ Related: <a href="#">{connection}</a></li>
            ))}
          </ul>
        </section>
      </>
    )}
  </div>
</BaseLayout>

<style>
  .container {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .back-link {
    color: var(--color-link);
    text-decoration: none;
    font-size: 0.85rem;
    margin-bottom: 2rem;
    display: inline-block;
    font-family: var(--font-sans);
    border: none;
  }

  .back-link:hover {
    color: var(--color-link-hover);
  }

  .article-header h1 {
    margin: 0 0 1.5rem 0;
    font-size: 2.6rem;
    line-height: 1.25;
    font-family: var(--font-sans);
    font-weight: 700;
  }

  .description {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    margin: 1.5rem 0;
    line-height: 1.7;
  }

  .metadata {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 1.5rem 0;
    font-family: var(--font-sans);
  }

  .tags {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  hr {
    margin: 2.5rem 0;
    border: none;
    border-top: 1px solid var(--color-border);
  }

  .prose {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text);
  }

  .connections {
    margin-top: 3rem;
  }

  .connections h2 {
    font-size: 1.3rem;
    margin: 0 0 1.5rem;
    font-family: var(--font-sans);
    font-weight: 600;
    border-bottom: none;
  }

  .connections ul {
    list-style: none;
    padding: 0;
  }

  .connections li {
    margin-bottom: 0.8rem;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
  }

  .connections a {
    color: var(--color-link);
    text-decoration: none;
    border-bottom: 1px solid var(--color-link);
  }

  @media (max-width: 768px) {
    .container {
      padding: 2rem 1.5rem;
    }

    .article-header h1 {
      font-size: 2rem;
    }

    .description {
      font-size: 1rem;
    }
  }

  @media (max-width: 640px) {
    .container {
      padding: 1.5rem 1rem;
    }

    .article-header h1 {
      font-size: 1.7rem;
    }
  }

  .connections a:hover {
    color: var(--color-link-hover);
  }
</style>
