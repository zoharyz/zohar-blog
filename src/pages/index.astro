---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TagCloud from '../components/TagCloud.astro';
import { getCollection } from 'astro:content';
import { getPublishedContent, sortContentByDate } from '../lib/content';
import { countTags } from '../lib/tags';

const essays = await getCollection('essays');
const snippets = await getCollection('snippets');

const publishedEssays = sortContentByDate(getPublishedContent(essays));
const publishedSnippets = sortContentByDate(getPublishedContent(snippets));

// Get all tags with counts
const allTags = countTags(essays, snippets);

// Get recent content for each type
const recentEssays = publishedEssays.slice(0, 5);
const recentSnippets = publishedSnippets.slice(0, 5);
---

<BaseLayout title="Zohar Yzgeav">
  <Header />
  <main class="container">
    <section class="hero">
      <h1>Zohar Yzgeav</h1>
      <p class="subtitle">Architecting systems at scale • AI engineering • Backend infrastructure</p>
      <p class="description">
        I write about building and scaling production systems with a focus on AI engineering, distributed systems, and backend architecture. These essays share lessons learned designing systems that handle complexity, leverage modern AI capabilities, and evolve as requirements change. Topics include system design, reliability patterns, infrastructure decisions, and the craft of building systems that teams can reason about and maintain.
      </p>
    </section>

    <TagCloud tags={allTags} />

    <section class="essays-section">
      <h2>Essays</h2>
      {publishedEssays.length === 0 ? (
        <p class="empty">No essays yet.</p>
      ) : (
        <ul class="article-preview">
          {recentEssays.map((essay) => {
            const slug = essay.id.replace(/\.mdx?$/, '');
            const tagsString = essay.data.tags?.join(',') || '';
            return (
              <li data-post-tags={tagsString}>
                <a href={`/essays/${slug}`} class="title">{essay.data.title}</a>
                <p class="meta">{essay.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
                {essay.data.tags && (
                  <div class="tags">
                    {essay.data.tags.map(tag => (
                      <span class="tag">#{tag}</span>
                    ))}
                  </div>
                )}
              </li>
            );
          })}
        </ul>
      )}
      <a href="/essays" class="view-all">View all essays →</a>
    </section>

    <section class="snippets-section">
      <h2>Write-ups</h2>
      {publishedSnippets.length === 0 ? (
        <p class="empty">No write-ups yet.</p>
      ) : (
        <ul class="article-preview">
          {recentSnippets.map((snippet) => {
            const slug = snippet.id.replace(/\.mdx?$/, '');
            const tagsString = snippet.data.tags?.join(',') || '';
            return (
              <li data-post-tags={tagsString}>
                <a href={`/snippets/${slug}`} class="title">{snippet.data.title}</a>
                <p class="meta">{snippet.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
                {snippet.data.tags && (
                  <div class="tags">
                    {snippet.data.tags.map(tag => (
                      <span class="tag">#{tag}</span>
                    ))}
                  </div>
                )}
              </li>
            );
          })}
        </ul>
      )}
      <a href="/snippets" class="view-all">View all write-ups →</a>
    </section>
  </main>
</BaseLayout>

<style>
  .container {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero {
    margin: 2rem 0 3rem;
  }

  h1 {
    font-size: 2.4rem;
    font-family: var(--font-sans);
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    margin: 0 0 1rem;
  }

  .description {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text);
    margin: 1rem 0 0;
  }

  .essays-section,
  .snippets-section {
    margin: 3rem 0;
  }

  h2 {
    font-size: 1.5rem;
    font-family: var(--font-sans);
    font-weight: 700;
    margin: 0 0 1rem;
  }

  .article-preview {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }

  .article-preview li {
    margin-bottom: 1.5rem;
  }

  .article-preview a {
    text-decoration: none;
    color: var(--color-text);
    font-weight: 600;
  }

  .article-preview a:hover {
    color: var(--color-link);
  }

  .title {
    display: block;
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .meta {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .tag {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .empty {
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .view-all {
    text-decoration: none;
    color: var(--color-link);
    font-weight: 500;
  }

  .view-all:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    h1 {
      font-size: 1.8rem;
    }

    h2 {
      font-size: 1.3rem;
    }

    .title {
      font-size: 1rem;
    }
  }
</style>
