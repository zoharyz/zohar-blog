---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import { getPublishedContent, sortContentByDate } from '../lib/content';

const essays = await getCollection('essays');
const snippets = await getCollection('snippets');

const publishedEssays = sortContentByDate(getPublishedContent(essays)).slice(0, 4);
const publishedSnippets = sortContentByDate(getPublishedContent(snippets)).slice(0, 3);
---

<BaseLayout title="Zohar Yzgeav">
  <Header />
  <main class="container">
    <section class="hero">
      <h1>Zohar Yzgeav</h1>
      <p class="subtitle">Architecting systems at scale • AI engineering • Backend infrastructure</p>
      <p class="description">
        I write about building and scaling production systems with a focus on AI engineering, distributed systems, and backend architecture. These essays share lessons learned designing systems that handle complexity, leverage modern AI capabilities, and evolve as requirements change. Topics include system design, reliability patterns, infrastructure decisions, and the craft of building systems that teams can reason about and maintain.
      </p>
    </section>

    <section class="essays-section">
      <h2>Essays</h2>
      {publishedEssays.length === 0 ? (
        <p class="empty">No essays yet.</p>
      ) : (
        <ul class="article-preview">
          {publishedEssays.map((essay) => {
            const slug = essay.id.replace(/\.mdx?$/, '');
            return (
              <li>
                <a href={`/essays/${slug}`} class="title">{essay.data.title}</a>
                <p class="meta">{essay.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
              </li>
            );
          })}
        </ul>
      )}
      <a href="/essays" class="view-all">View all essays →</a>
    </section>

    <section class="snippets-section">
      <h2>Snippets</h2>
      {publishedSnippets.length === 0 ? (
        <p class="empty">No snippets yet.</p>
      ) : (
        <ul class="article-preview">
          {publishedSnippets.map((snippet) => {
            const slug = snippet.id.replace(/\.mdx?$/, '');
            return (
              <li>
                <a href={`/snippets/${slug}`} class="title">{snippet.data.title}</a>
                <p class="meta">{snippet.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
              </li>
            );
          })}
        </ul>
      )}
      <a href="/snippets" class="view-all">View all snippets →</a>
    </section>
  </main>
</BaseLayout>

<style>
  .container {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero {
    margin: 3.5rem 0 4rem;
  }

  .hero h1 {
    font-size: 2.8rem;
    font-family: var(--font-sans);
    font-weight: 700;
    margin: 0 0 1rem;
    line-height: 1.2;
  }

  .subtitle {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    margin: 0.5rem 0;
    font-weight: 500;
  }

  .description {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 1.5rem 0 0;
    max-width: 100%;
    font-family: var(--font-serif);
  }

  .essays-section,
  .snippets-section {
    margin-bottom: 4rem;
  }

  .essays-section h2,
  .snippets-section h2 {
    font-size: 1.6rem;
    font-family: var(--font-sans);
    font-weight: 700;
    margin: 2.5rem 0 1.5rem;
    border-bottom: none;
    padding-bottom: 0;
  }

  .article-preview {
    list-style: none;
    padding: 0;
    margin: 2rem 0;
  }

  .article-preview li {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article-preview li:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .article-preview .title {
    display: block;
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    margin-bottom: 0.4rem;
    line-height: 1.4;
    border: none;
  }

  .article-preview .title:hover {
    color: var(--color-link);
  }

  .article-preview .meta {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .view-all {
    display: inline-block;
    color: var(--color-link);
    text-decoration: none;
    font-weight: 500;
    font-family: var(--font-sans);
  }

  .view-all:hover {
    color: var(--color-link-hover);
    text-decoration: underline;
  }

  .empty {
    color: var(--color-text-muted);
    font-style: italic;
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .hero h1 {
      font-size: 2.2rem;
    }

    .subtitle {
      font-size: 1rem;
    }

    .description {
      font-size: 0.95rem;
    }
  }

  @media (max-width: 640px) {
    .hero {
      margin: 2rem 0 3rem;
    }

    .hero h1 {
      font-size: 1.8rem;
    }
  }
</style>
