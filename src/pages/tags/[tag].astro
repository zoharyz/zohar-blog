---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import { getCollection } from 'astro:content';
import { getPublishedContent, getContentByTag, getAllTags, sortContentByDate } from '../../lib/content';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  const snippets = await getCollection('snippets');

  const allContent = [
    ...getPublishedContent(essays),
    ...getPublishedContent(snippets),
  ];

  const tags = getAllTags(allContent);

  return tags.map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

interface Props {
  tag: string;
}

const { tag } = Astro.props;

const essays = await getCollection('essays');
const snippets = await getCollection('snippets');

const allContent = [
  ...getPublishedContent(essays),
  ...getPublishedContent(snippets),
];

const tagged = sortContentByDate(getContentByTag(allContent, tag));
---

<BaseLayout title={`Tag: ${tag}`} description={`Articles tagged with "${tag}"`}>
  <Header />
  <main class="container">
    <h1>Tag: {tag}</h1>
    <p class="subtitle">{tagged.length} article{tagged.length !== 1 ? 's' : ''}</p>

    {tagged.length === 0 ? (
      <p class="empty">No articles found with this tag.</p>
    ) : (
      <div class="article-list">
        <ul>
          {tagged.map((item) => {
            const slug = item.id.replace(/\.mdx?$/, '');
            return (
              <li>
                <a href={`/${item.collection}/${slug}`} class="title">{item.data.title}</a>
                <p class="meta">
                  <time>{item.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
                </p>
                <p class="description">{item.data.description}</p>
              </li>
            );
          })}
        </ul>
      </div>
    )}
  </main>
</BaseLayout>

<style>
  .container {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  h1 {
    font-size: 2.4rem;
    font-family: var(--font-sans);
    font-weight: 700;
    margin: 0 0 1rem;
  }

  .subtitle {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    margin: 0 0 2.5rem;
    font-family: var(--font-sans);
  }

  .article-list ul {
    list-style: none;
    padding: 0;
  }

  .article-list li {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }

  .title {
    display: block;
    font-size: 1.3rem;
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    margin-bottom: 0.5rem;
    line-height: 1.4;
    border: none;
  }

  .title:hover {
    color: var(--color-link);
  }

  .meta {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0.5rem 0;
    font-family: var(--font-sans);
  }

  .description {
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-top: 0.75rem;
    font-size: 0.95rem;
  }

  .empty {
    color: var(--color-text-muted);
    font-style: italic;
    text-align: center;
    padding: 3rem 0;
  }

  @media (max-width: 768px) {
    .container {
      padding: 2rem 1.5rem;
    }

    h1 {
      font-size: 1.8rem;
    }
  }
</style>
