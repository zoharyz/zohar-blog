---
interface Props {
  tags: { tag: string; count: number }[];
  selectedTag?: string | null;
}

const { tags, selectedTag } = Astro.props;
---

<div class="tag-cloud">
  <div class="tags">
    {tags.map(({ tag, count }) => (
      <button
        class={`tag ${selectedTag === tag ? 'active' : ''}`}
        data-tag={tag}
      >
        #{tag} <span class="count">({count})</span>
      </button>
    ))}
  </div>
</div>

<style>
  .tag-cloud {
    margin: 3rem 0;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag {
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    padding: 0.5rem 0.75rem;
    border-radius: 0.25rem;
    cursor: pointer;
    font-size: 0.9rem;
    font-family: var(--font-sans);
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .tag:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }

  .tag.active {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  .count {
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .tag {
      font-size: 0.85rem;
      padding: 0.4rem 0.6rem;
    }
  }
</style>

<script>
  // Client-side tag filtering
  const tagButtons = document.querySelectorAll('[data-tag]');

  tagButtons.forEach(button => {
    button.addEventListener('click', () => {
      const tag = button.getAttribute('data-tag');
      const articles = document.querySelectorAll('[data-post-tags]');

      if (button.classList.contains('active')) {
        // Deselect tag
        button.classList.remove('active');
        articles.forEach(article => article.style.display = 'block');
      } else {
        // Remove active from all buttons
        tagButtons.forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');

        // Filter articles
        articles.forEach(article => {
          const postTags = article.getAttribute('data-post-tags')?.split(',') || [];
          article.style.display = postTags.includes(tag) ? 'block' : 'none';
        });
      }
    });
  });
</script>
